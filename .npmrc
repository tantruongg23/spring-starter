# Default public registry
registry=https://registry.npmjs.org/

# Private scope (company packages)
#@your-scope:registry=https://nexus.company.com/repository/npm/

# Auth (use env variable, NEVER hardcode)
# Example for Nexus / Artifactory
#//nexus.company.com/repository/npm/:_authToken=${NPM_TOKEN}

# Always require auth for private registry
always-auth=false